#include <dt-bindings/zmk/matrix_transform.h> // Put this with the other includes at the top of your dtsi
/ {
    kscan0: kscan0 {
        compatible = "zmk,kscan-gpio-matrix";
        diode-direction = "col2row";
        wakeup-source;

        row-gpios
            = <&pxiao_d 6 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 7 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 8 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 9 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            , <&xiao_d 10 (GPIO_ACTIVE_HIGH | GPIO_PULL_DOWN)>
            ;


/ {
    default_transform: keymap_transform0 {
        compatible = "zmk,matrix-transform";
        columns = <12>;
        rows = <4>;
        map = <
        //  LKey 1 |LKey 2 |LKey 3 LKey 4 |LKey 5 |LKey 6         RKey 1 |RKey 2 |RKey 3      RKey 4 |RKey 5 |RKey 6    
          
            RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)       RC(0,0) RC(0,1) RC(0,2) RC(0,3) RC(0,4) RC(0,5)
        //  LKey 7 |LKey 8 |LKey 9 LKey 10 |LKey 11 |LKey 12      RKey 7 |RKey 8 |RKey 9      RKey 10 |RKey 11 |RKey 12

           
            RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)        RC(1,0) RC(1,1) RC(1,2) RC(1,3) RC(1,4) RC(1,5)       
      
        //  LKey 13 |LKey 14 |LKey 15  LKey 16 |LKey 17|LKey 18   RKey 13 |RKey 14 |RKey 15      RKey 16 |RKey 17 |RKey 18    
           
            RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)       RC(2,0) RC(2,1) RC(2,2) RC(2,3) RC(2,4) RC(2,5)


        //  LKey 19 |LKey 20 |LKey 21  LKey 22 |LKey 23 |LKey 24   RKey 19 |RKey 20 |RKey 21      RKey 22 |RKey 23 |RKey 24    
           
            RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)       RC(3,0) RC(3,1) RC(3,2) RC(3,3) RC(3,4) RC(3,5)
        >;
    };
};
    };
};
